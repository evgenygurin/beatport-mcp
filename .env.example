# Beatport account credentials (OAuth2 password grant)
BEATPORT_USERNAME=you@example.com
BEATPORT_PASSWORD=your-password

# Optional: override the OAuth client_id (defaults to Beatport's public docs client)
# BEATPORT_CLIENT_ID=

# Optional: where to cache the OAuth token (default: ~/.beatport-mcp/token.json)
# BEATPORT_TOKEN_FILE=/path/to/token.json

# Optional: read-only mode — hide the mutating playlist tools
# (create/add/remove/delete) for a safe, browse-only deployment
# BEATPORT_READ_ONLY=1

# Optional: also mount the spec-driven OpenAPI server under the `raw_`
# namespace (one schema'd tool per Beatport v4 operation)
# BEATPORT_INCLUDE_RAW=1

# Optional: transport for the MCP server: stdio (default) or http
# BEATPORT_MCP_TRANSPORT=stdio
# BEATPORT_MCP_HOST=127.0.0.1
# BEATPORT_MCP_PORT=8000
